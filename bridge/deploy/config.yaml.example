# /etc/grafana-bridge/config.yaml
# Lives on pibridge. Lists Grafana panels to rotate through on the X3.

grafana_url: https://YOUR-STACK.grafana.net
width: 792
height: 528
cache_dir: /var/lib/grafana-bridge

panels:
  # Find dashboard_uid + dashboard_slug in any Grafana dashboard URL:
  #   /d/<uid>/<slug>
  # panel_id is the "panel ID" shown in panel inspect → JSON.

  - name: cpu_overview
    dashboard_uid: REPLACE_ME
    dashboard_slug: node-exporter-full
    panel_id: 77
    from: now-6h
    to: now
    dwell_seconds: 300

  - name: memory
    dashboard_uid: REPLACE_ME
    dashboard_slug: node-exporter-full
    panel_id: 78
    from: now-6h
    to: now
    dwell_seconds: 300
