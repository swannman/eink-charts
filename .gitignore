__pycache__/
*.pyc
.venv/
.pytest_cache/
*.egg-info/
dist/
build/
.DS_Store
*.bin

bridge-cloud/local-config.yaml
bridge-cloud/local.env

firmware-cloud/platformio.local.ini
firmware-cloud/src/secrets.h
firmware-cloud/.pio/
firmware-cloud/.vscode/

# Xcode build artifacts + the per-developer Config.swift (real bearer
# token). Keep the template, exclude the filled-in copy.
ios-app/EInkCharts/Config.swift
# Auto-generated by Xcode 26 (we use GENERATE_INFOPLIST_FILE=YES + build
# settings instead of a hand-maintained Info.plist).
ios-app/EInkCharts/Info.plist
# Default Xcode template assets — users will get their own when they
# create the project locally per ios-app/README.md.
ios-app/EInkCharts/Assets.xcassets/
ios-app/*.xcodeproj/
ios-app/*.xcworkspace/
ios-app/DerivedData/
ios-app/build/
*.xcuserstate
xcuserdata/

# Local-only credential backups.
*.h.bak
