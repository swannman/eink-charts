# /etc/default/grafana-push
# Owned root:grafana-bridge, mode 0640.
#
# Read by grafana-push.service alongside /etc/default/grafana-bridge.

# Auth for pushing to the public Worker. Must match the Worker's
# BEARER_TOKEN secret in Cloudflare.
WORKER_BEARER_TOKEN=REPLACE_ME

# X3's X25519 public key, base64url (44 chars, padding optional). Obtained
# from the QR code or serial log on first X3 boot. Leave blank until the
# X3 is provisioned — the timer will no-op with a warning until set.
X3_PUBKEY_B64=

# Optional overrides:
# WORKER_URL=https://dashboard.contexa.net/bundle
# LOG_LEVEL=INFO
